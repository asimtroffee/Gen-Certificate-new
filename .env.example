# ==========================================
# Production Environment Variables Example
# ==========================================

# 1. Supabase Settings (Required)
# Get these from your Supabase Project Settings -> API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"

# 2. CORS Settings (Optional)
# A comma-separated list of allowed origins.
# Leave empty or omit to allow all origins ('*').
# ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# 3. SMTP Settings (Optional - can also be configured via Supabase 'config' table)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your.email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Your Organization Name"

# 4. App URL (Used for generating magic links)
PUBLIC_URL="https://your-production-domain.com"

# 5. Form Watcher Settings (Optional)
# FORM_SHEET_ID=""
# FORM_POLL_INTERVAL="30"
